# Supabase — create a project at https://supabase.com and copy these from
# Project Settings → API. The app runs in a mock/demo mode if these are unset,
# so you can develop the full UI before wiring the backend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Future integrations (not required for the UI to run) ---
# Voice AI (Vapi.ai or Retell AI)
# VAPI_API_KEY=
# Stripe
# STRIPE_SECRET_KEY=
# Twilio (SMS reminders)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
