# ===========================================================================
#  PracticeVoice AI — environment variables
#  VITE_* vars are read by the frontend (safe to expose). Everything WITHOUT a
#  VITE_ prefix is server-only (Netlify Functions) and must never be public.
#  Set these in Netlify → Site configuration → Environment variables.
# ===========================================================================

# --- Supabase (auth + database) -------------------------------------------
# From your Supabase project → Settings → API. When set, the app uses real auth
# AND the dashboard shows real calls/appointments (not the demo data).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Service-role key (SERVER ONLY — never prefix with VITE_). Used by the webhook
# and reminder functions to write/read calls and appointments (bypasses RLS).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Demo mode ------------------------------------------------------------
# Local `npm run dev` is always demo mode. For a PUBLIC demo deploy set "true".
# If blank on a production build WITHOUT Supabase keys, login is disabled on
# purpose (fail-closed) so a misconfigured deploy can't accept any password.
VITE_DEMO_MODE=

# --- Stripe ---------------------------------------------------------------
# Checkout runs on Stripe Payment Links set in src/data/plans.ts.
#
# Subscription gating (optional, OFF by default): when you want a paid plan to
# be REQUIRED for dashboard access, turn this on and set the webhook secret.
#   1. In Stripe → Developers → Webhooks, add an endpoint:
#        https://practicevoice-ai.com/.netlify/functions/stripe-webhook
#      subscribe to checkout.session.completed + customer.subscription.*
#   2. Copy its Signing secret (whsec_…) into STRIPE_WEBHOOK_SECRET below.
#   3. Configure a 14-day trial on each Payment Link (Stripe → Payment Links).
#   4. Set VITE_BILLING_ENABLED=true to enforce it in the app (build-time var).
VITE_BILLING_ENABLED=
STRIPE_WEBHOOK_SECRET=
# STRIPE_SECRET_KEY=  # not required for the Payment-Link + webhook flow

# --- Twilio (SMS — used by netlify/functions/send-sms.mjs) ----------------
# From your Twilio console. The Auth Token is secret; keep it server-only.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Retell AI (voice — used by netlify/functions/retell-webhook.mjs) ------
# Your Retell API key. Used to VERIFY that webhook calls really come from Retell
# (HMAC signature). Strongly recommended before launch. From Retell → Settings.
RETELL_API_KEY=
# For a single practice: the clinic id (from the Supabase `clinics` table) that
# every incoming call is attached to. Simplest way to wire calls → dashboard.
# (Multi-practice alternative: leave blank and set clinics.retell_number instead.)
DEFAULT_CLINIC_ID=
# Optional: flat dollar value to attribute to each booking when the agent
# doesn't extract a specific revenue figure. Powers the revenue dashboard.
# DEFAULT_BOOKING_VALUE=200

# Optional overrides for the server-sent confirmation / reminder texts.
# CLINIC_NAME=
# SMS_CONFIRMATION_TEMPLATE=
# SMS_REMINDER_TEMPLATE=

# --- Abuse guard (optional) -----------------------------------------------
# If set, the send-sms function only accepts requests from this origin.
# ALLOWED_ORIGIN=https://practicevoice-ai.com
