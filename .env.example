# Supabase — create a project at https://supabase.com and copy these from
# Project Settings → API. When set, the app uses real authentication.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Demo mode. Local `npm run dev` is always demo mode. For a PUBLIC demo deploy
# (mock login, sample data, no backend) set this to "true". If you leave it
# blank on a production build WITHOUT Supabase keys, login is disabled on
# purpose (fail-closed) so a misconfigured deploy can't accept any password.
VITE_DEMO_MODE=

# --- Stripe (frontend is ready; see src/lib/checkout.ts) ---
# Create three Prices in Stripe and paste their Price IDs here to wire up the
# pricing buttons. Leave blank until you're ready — the buttons still work
# (they route to the free-trial signup).
VITE_STRIPE_PRICE_BASIC=
VITE_STRIPE_PRICE_PROFESSIONAL=
VITE_STRIPE_PRICE_PREMIUM=
# Server-side Stripe secret (used later when you build the Checkout Session)
# STRIPE_SECRET_KEY=

# --- Other future integrations (not required for the UI to run) ---
# Voice AI (Vapi.ai or Retell AI)
# VAPI_API_KEY=
# Twilio (SMS reminders)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
